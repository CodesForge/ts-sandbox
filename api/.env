# ─── App ──────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
SERVER_HOSTNAME=0.0.0.0
SERVER_PORT=8080
CORS_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ──────────────
DATABASE_URL=postgres://feed:feed@localhost:5432/feed
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# ─── Cache (Redis) ───────────────────────
REDIS_URL=redis://:feed@localhost:6379

# ─── Auth (JWT) ──────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long

# ─── Docs ────────────────────────────────
ENABLE_OPENAPI=true
